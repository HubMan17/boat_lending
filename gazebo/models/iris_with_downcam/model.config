<?xml version="1.0"?>
<model>
  <name>iris_with_downcam</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>boat_lending</name>
  </author>
  <description>
    Wrapper model: iris_with_ardupilot + fixed downward-facing camera
    (640x480, 10Hz, GstCameraPlugin streaming H.264/RTP on UDP:5600).
    Used by Phase 3b precision-landing bring-up. No gimbal.
  </description>
  <depend>
    <model>
      <uri>model://iris_with_ardupilot</uri>
      <version>2.0</version>
    </model>
  </depend>
</model>
